import java.util.*;

class Ticket {
    int id;
    String title;
    String description;
    String status;
    String assignedTo;

    Ticket(int id, String title, String description) {
        this.id = id;
        this.title = title;
        this.description = description;
        this.status = "OPEN";
        this.assignedTo = "Unassigned";
    }

    public String toString() {
        return "ID: " + id + " | Title: " + title + " | Status: " + status + " | Assigned To: " + assignedTo;
    }
}

public class TicketManagement {
    static Scanner sc = new Scanner(System.in);
    static ArrayList<Ticket> tickets = new ArrayList<>();
    static int idCounter = 1;

    static void createTicket() {
        sc.nextLine();
        System.out.print("Enter title: ");
        String title = sc.nextLine();
        System.out.print("Enter description: ");
        String desc = sc.nextLine();

        tickets.add(new Ticket(idCounter++, title, desc));
        System.out.println("Ticket created");
    }

    static void viewTickets() {
        if (tickets.isEmpty()) {
            System.out.println("No tickets available");
            return;
        }
        for (Ticket t : tickets) {
            System.out.println(t);
        }
    }

    static Ticket findTicket(int id) {
        for (Ticket t : tickets) {
            if (t.id == id) return t;
        }
        return null;
    }

    static void assignTicket() {
        System.out.print("Enter ticket ID: ");
        int id = sc.nextInt();
        sc.nextLine();
        Ticket t = findTicket(id);
        if (t != null) {
            System.out.print("Assign to: ");
            t.assignedTo = sc.nextLine();
            System.out.println("Assigned successfully");
        } else {
            System.out.println("Ticket not found");
        }
    }

    static void updateStatus() {
        System.out.print("Enter ticket ID: ");
        int id = sc.nextInt();
        sc.nextLine();
        Ticket t = findTicket(id);
        if (t != null) {
            System.out.print("Enter status (OPEN/IN_PROGRESS/CLOSED): ");
            t.status = sc.nextLine();
            System.out.println("Status updated");
        } else {
            System.out.println("Ticket not found");
        }
    }

    static void deleteTicket() {
        System.out.print("Enter ticket ID: ");
        int id = sc.nextInt();
        Ticket t = findTicket(id);
        if (t != null) {
            tickets.remove(t);
            System.out.println("Deleted successfully");
        } else {
            System.out.println("Ticket not found");
        }
    }

    public static void main(String[] args) {
        while (true) {
            System.out.println("\n1.Create Ticket\n2.View Tickets\n3.Assign Ticket\n4.Update Status\n5.Delete Ticket\n6.Exit");
            int choice = sc.nextInt();

            switch (choice) {
                case 1:
                    createTicket();
                    break;
                case 2:
                    viewTickets();
                    break;
                case 3:
                    assignTicket();
                    break;
                case 4:
                    updateStatus();
                    break;
                case 5:
                    deleteTicket();
                    break;
                case 6:
                    System.exit(0);
                default:
                    System.out.println("Invalid choice");
            }
        }
    }
}
